{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YA Music Widget",
  "version": "0.1.0",
  "identifier": "ru.linskay.ymv",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173"
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Linskay",
    "category": "Music",
    "shortDescription": "Cyberpunk Yandex Music desktop widget",
    "longDescription": "Cyberpunk desktop overlay widget for Yandex Music with Java backend, Playwright control, WebSocket sync and tray mode.",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "resources": [
      "../target/ya-music-vidjet-0.1.0-SNAPSHOT.jar"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["Russian", "English"],
        "createDesktopShortcut": true,
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/linskay/ya-music-vidjet/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "PASTE_TAURI_UPDATER_PUBLIC_KEY_HERE"
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "YA Music Widget",
        "width": 980,
        "height": 460,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "resizable": false,
        "skipTaskbar": true,
        "visible": true
      }
    ]
  }
}
